<Page
    x:Class="FitAppMVVM.Presentation.AddExercisePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FitAppMVVM.Presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <!-- Remove DataContext binding from StackPanel -->
        <StackPanel Spacing="20">
            <TextBlock Text="Exercise Name:" 
                      Style="{StaticResource InputLabelStyle}"/>
            <TextBox Text="{x:Bind ViewModel.ExerciseName, Mode=TwoWay}" 
                    PlaceholderText="Exercise Name"/>
            
            <TextBlock Text="Number of Sets:" 
                      Style="{StaticResource InputLabelStyle}"/>
            <TextBox Text="{x:Bind ViewModel.Sets, Mode=TwoWay}" 
                    PlaceholderText="Sets" InputScope="Number"/>

            <TextBlock Text="Repetitions per Set:" 
                      Style="{StaticResource InputLabelStyle}"/>
            <TextBox Text="{x:Bind ViewModel.Reps, Mode=TwoWay}" 
                    PlaceholderText="Reps" InputScope="Number"/>
            
            <TextBlock Text="Weight" 
                      Style="{StaticResource InputLabelStyle}"/>
            <TextBox Text="{x:Bind ViewModel.Weight, Mode=TwoWay}" 
                    PlaceholderText="Weight" InputScope="Number"/>

            <Button Content="Add Exercise"
                    Command="{x:Bind ViewModel.AddExerciseCommand}"
                    HorizontalAlignment="Center"/>

            <Button Content="Back" Click="GoBack_Click"/>
        </StackPanel>
    </Grid>
</Page>
